<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Barra de color según prioridad -->
        <View
            android:id="@+id/viewPrioridad"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#F44336"
            android:layout_marginEnd="12dp"/>

        <!-- Icono según tipo -->
        <ImageView
            android:id="@+id/imgIconoTipo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="#7B2CBF"
            android:contentDescription="Icono tipo"
            android:layout_marginEnd="12dp"/>

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vacuna antirrábica vencida"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <!-- Mascota -->
            <TextView
                android:id="@+id/tvMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾 Firulais"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp"/>

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="La vacuna está vencida hace 2 meses"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp"/>

            <!-- Fecha y atraso -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- Fecha -->
                <TextView
                    android:id="@+id/tvFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 01/01/2026"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginEnd="12dp"/>

                <!-- Días de atraso -->
                <TextView
                    android:id="@+id/tvAtraso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ 60 días atrasado"
                    android:textSize="12sp"
                    android:textColor="#F44336"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDIENTE"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/chip_purple"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_gravity="top"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>